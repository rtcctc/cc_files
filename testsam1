-- =========================
-- CONFIG
-- =========================

local CONFIG_FILE = "vote_config"

local monitor = peripheral.find("monitor")

if not monitor then
    error("Монитор не найден")
end

monitor.setTextScale(0.5)

-- =========================
-- LOAD/SAVE CONFIG
-- =========================

local config = {}

local function saveConfig()
    local f = fs.open(CONFIG_FILE, "w")
    f.write(textutils.serialize(config))
    f.close()
end

local function loadConfig()
    if fs.exists(CONFIG_FILE) then
        local f = fs.open(CONFIG_FILE, "r")
        config = textutils.unserialize(f.readAll())
        f.close()
        return true
    end
    return false
end

local function setupConfig()
    term.clear()
    term.setCursorPos(1,1)

    print("=== Первая настройка ===")
    print()

    write("Сторона кнопки ЗА: ")
    config.yes = read()

    write("Сторона кнопки ПРОТИВ: ")
    config.no = read()

    write("Сторона кнопки ВОЗДЕРЖАЛСЯ: ")
    config.abstain = read()

    write("Сторона кнопки СТОП: ")
    config.stop = read()

    saveConfig()

    print("Настройки сохранены")
    sleep(2)
end

if not loadConfig() then
    setupConfig()
end

-- =========================
-- MEETING INFO
-- =========================

term.clear()
term.setCursorPos(1,1)

write("Тема собрания: ")
local meetingTitle = read()

write("Номер собрания: ")
local meetingNumber = read()

-- =========================
-- PARTICIPANTS
-- =========================

local participants = {}

print()
print("Введите участников")
print("0 - закончить")

while true do
    local name = read()

    if name == "0" then
        break
    end

    table.insert(participants, name)
end

local participantCount = #participants

-- =========================
-- DRAW UI
-- =========================

local function clearMonitor()
    monitor.setBackgroundColor(colors.black)
    monitor.clear()
end

local function centerText(y, text, color)
    local w, h = monitor.getSize()

    monitor.setTextColor(color or colors.white)
    monitor.setCursorPos(math.floor((w - #text) / 2), y)
    monitor.write(text)
end

local function drawFrame()
    clearMonitor()

    local w, h = monitor.getSize()

    -- Вертикальная линия
    for y=1,h do
        monitor.setCursorPos(math.floor(w/2), y)
        monitor.write("|")
    end

    -- Горизонтальная линия
    for x=1,w do
        monitor.setCursorPos(x, 6)
        monitor.write("-")
    end

    centerText(1, "СОБРАНИЕ #" .. meetingNumber, colors.cyan)
    centerText(2, meetingTitle, colors.white)

    -- Участники
    monitor.setCursorPos(2, 4)
    monitor.setTextColor(colors.lime)
    monitor.write("Участники: " .. participantCount)

    local y = 7

    for _,name in ipairs(participants) do
        monitor.setCursorPos(2, y)
        monitor.setTextColor(colors.white)
        monitor.write(name)
        y = y + 1
    end
end

drawFrame()

-- =========================
-- VOTE BAR
-- =========================

local function drawVoteBar(yes, no, abstain)
    local w, h = monitor.getSize()

    local total = participantCount

    local pending = total - yes - no - abstain

    local barWidth = math.floor(w/2) - 4
    local startX = math.floor(w/2) + 2
    local y = 10

    monitor.setCursorPos(startX, 7)
    monitor.setTextColor(colors.orange)
    monitor.write("ГОЛОСОВАНИЕ")

    local function segment(count)
        return math.floor((count / total) * barWidth)
    end

    local greenW = segment(yes)
    local redW = segment(no)
    local yellowW = segment(abstain)

    local used = greenW + redW + yellowW
    local grayW = barWidth - used

    local x = startX

    monitor.setBackgroundColor(colors.green)
    for i=1,greenW do
        monitor.setCursorPos(x, y)
        monitor.write(" ")
        x=x+1
    end

    monitor.setBackgroundColor(colors.red)
    for i=1,redW do
        monitor.setCursorPos(x, y)
        monitor.write(" ")
        x=x+1
    end

    monitor.setBackgroundColor(colors.yellow)
    for i=1,yellowW do
        monitor.setCursorPos(x, y)
        monitor.write(" ")
        x=x+1
    end

    monitor.setBackgroundColor(colors.gray)
    for i=1,grayW do
        monitor.setCursorPos(x, y)
        monitor.write(" ")
        x=x+1
    end

    monitor.setBackgroundColor(colors.black)

    monitor.setCursorPos(startX, 12)
    monitor.setTextColor(colors.green)
    monitor.write("За: " .. yes)

    monitor.setCursorPos(startX, 13)
    monitor.setTextColor(colors.red)
    monitor.write("Против: " .. no)

    monitor.setCursorPos(startX, 14)
    monitor.setTextColor(colors.yellow)
    monitor.write("Воздерж.: " .. abstain)

    monitor.setCursorPos(startX, 15)
    monitor.setTextColor(colors.lightGray)
    monitor.write("Нет ответа: " .. pending)
end

-- =========================
-- VOTING
-- =========================

local voteRunning = false

local function runVote()

    if voteRunning then
        print("Голосование уже идёт")
        return
    end

    voteRunning = true

    write("Тема голосования: ")
    local topic = read()

    drawFrame()

    local w,h = monitor.getSize()

    monitor.setCursorPos(math.floor(w/2)+2,4)
    monitor.setTextColor(colors.white)
    monitor.write(topic)

    local yes = 0
    local no = 0
    local abstain = 0

    drawVoteBar(yes,no,abstain)

    local votes = 0

    while votes < participantCount and voteRunning do

        local event, side = os.pullEvent("redstone")

        if redstone.getInput(config.yes) then
            yes = yes + 1
            votes = votes + 1

        elseif redstone.getInput(config.no) then
            no = no + 1
            votes = votes + 1

        elseif redstone.getInput(config.abstain) then
            abstain = abstain + 1
            votes = votes + 1

        elseif redstone.getInput(config.stop) then
            voteRunning = false
            break
        end

        drawVoteBar(yes,no,abstain)
    end

    monitor.setCursorPos(math.floor(w/2)+2,18)

    if yes > no then
        monitor.setTextColor(colors.green)
        monitor.write("ПРИНЯТО")
    else
        monitor.setTextColor(colors.red)
        monitor.write("ОТКЛОНЕНО")
    end

    voteRunning = false
end

-- =========================
-- MAIN LOOP
-- =========================

while true do

    term.setCursorPos(1,20)
    term.clearLine()

    write("> ")

    local cmd = read()

    if cmd == "vote" then
        runVote()

    elseif cmd == "stopvote" then
        voteRunning = false

    elseif cmd == "exit" then
        break
    end
end
